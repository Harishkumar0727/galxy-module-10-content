FLASK_APP=run.py
FLASK_ENV=development
FLASK_RUN_PORT=5000

# MongoDB Configuration
MONGO_URI=mongodb+srv://your_db_username:your_db_password@your_cluster.mongodb.net/your_db_name?appName=your_cluster_app_name
MONGO_DB_NAME=galxy

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# JWT Authentication Config (From Module 1)
JWT_SECRET=your_jwt_secret_key_here

# CORS Configuration origin list (e.g. *, or https://your-frontend.com)
CORS_ALLOWED_ORIGINS=*
